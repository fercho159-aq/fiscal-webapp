# =============================================================================
# fiscal-webapp .env — completa cada valor
# REGLAS:
#   - Valores SIN espacios ni #/,/: → SIN comillas
#   - Valores CON espacios, #, /, : → CON comillas dobles
#   - URLs sin / al final
#   - APP_DOMAIN: solo hostname (sin https://, sin /)
# =============================================================================

# --- Dominio ---
# Hostname puro. Caddy obtiene TLS automático vía Let's Encrypt.
# IMPORTANTE: DNS A record fiscal.tudominio.com → IP_VPS debe estar configurado.
APP_DOMAIN=fiscal.tudominio.com

# --- Auth.js ---
# AUTH_SECRET: lo genera vps-bootstrap.sh automáticamente
AUTH_SECRET=
# URL pública del sitio (sin / al final)
AUTH_URL=https://fiscal.tudominio.com
# CSV de dominios permitidos para magic links. Vacío = abierto a cualquier email.
ALLOWED_EMAIL_DOMAINS=tudominio.com

# --- Email (Resend para magic links) ---
# https://resend.com → Settings → API Keys
RESEND_API_KEY=re_xxx
# Si NO has verificado tu dominio en Resend, usa onboarding@resend.dev
# Si SÍ verificaste tudominio.com, usa no-reply@tudominio.com
AUTH_EMAIL_FROM=onboarding@resend.dev

# --- Postgres ---
# Lo genera vps-bootstrap.sh
POSTGRES_PASSWORD=

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-xxx
# Opcional, solo para queries no-sensibles
DEEPSEEK_API_KEY=
# Para embeddings RAG (text-embedding-3-large)
OPENAI_API_KEY=sk-xxx

# --- Qdrant ---
# Lo genera vps-bootstrap.sh
QDRANT_API_KEY=

# --- MinIO (S3-compatible) ---
MINIO_ROOT_USER=fiscal-admin
# Lo genera vps-bootstrap.sh
MINIO_ROOT_PASSWORD=
S3_BUCKET=fiscal-docs
S3_REGION=us-east-1

# --- Membrete para export DOCX (opcional) ---
# IMPORTANTE: VALORES CON ESPACIOS DEBEN IR ENTRE COMILLAS DOBLES
MEMBRETE_LINE_1="Despacho de Asesoría Fiscal"
MEMBRETE_LINE_2="Av. Principal 123, Col. Centro, CP 00000"

# --- Email del primer admin (seed para magic link) ---
SEED_ADMIN_EMAIL=tu@correo.com

# --- Admin hardcoded (login email + password directo, sin Resend) ---
# Para testing rápido. Se crea como ADMIN en DB al primer login.
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=cambia-esto-en-produccion

# Dominio (subdomain en VPS) — Caddy obtiene TLS automático
APP_DOMAIN=fiscal.tudominio.com

# Auth.js
AUTH_SECRET=    # genera con: openssl rand -hex 32
AUTH_URL=https://fiscal.tudominio.com
ALLOWED_EMAIL_DOMAINS=despacho.com,tudominio.com   # CSV. Vacío = abierto

# Email (Resend para magic links)
RESEND_API_KEY=re_xxx
AUTH_EMAIL_FROM=no-reply@tudominio.com

# Postgres
POSTGRES_PASSWORD=    # genera con: openssl rand -hex 24

# LLM
ANTHROPIC_API_KEY=sk-ant-xxx
DEEPSEEK_API_KEY=     # opcional, solo para queries no-sensibles
OPENAI_API_KEY=sk-xxx # para embeddings (RAG)

# Qdrant
QDRANT_API_KEY=       # genera con: openssl rand -hex 32

# MinIO (S3-compatible)
MINIO_ROOT_USER=fiscal-admin
MINIO_ROOT_PASSWORD=  # genera con: openssl rand -hex 24
S3_BUCKET=fiscal-docs
S3_REGION=us-east-1

# Membrete para export DOCX (opcional)
MEMBRETE_LINE_1=Despacho de Asesoría Fiscal
MEMBRETE_LINE_2=Av. Principal #123, Col. Centro, CP 00000

# Email del primer admin (seed)
SEED_ADMIN_EMAIL=fernandotrejo@solucionesmaw.com

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ====== AUTH (Auth.js) ======

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())

  accounts Account[]
  sessions Session[]
  casos    Caso[]
  mensajes Mensaje[]
}

enum Role {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ====== DOMAIN ======

model Caso {
  id               String   @id @default(cuid())
  userId           String
  titulo           String
  expedienteNumero String?
  rfcContribuyente String?
  razonSocial      String?
  autoridadEmisora String?
  montoTotal       Decimal? @db.Decimal(20, 2)
  estadoProcesal   String?
  plazoProximo     DateTime?
  notas            String?  @db.Text
  archivado        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentos  Documento[]
  mensajes    Mensaje[]
  sintesis    Sintesis[]

  @@index([userId])
  @@index([rfcContribuyente])
}

model Documento {
  id            String   @id @default(cuid())
  casoId        String
  nombre        String
  tipoDocumento TipoDocumento
  storageKey    String  // ruta en MinIO/S3
  mimeType      String
  tamanoBytes   Int
  textoExtraido String?  @db.Text
  ocrAplicado   Boolean  @default(false)
  fechaEmision  DateTime?
  metadatos     Json?    // tablas créditos, fechas detectadas, etc.
  createdAt     DateTime @default(now())

  caso Caso @relation(fields: [casoId], references: [id], onDelete: Cascade)

  @@index([casoId])
}

enum TipoDocumento {
  OFICIO_SAT
  RESOLUCION_TFJA
  ACUERDO_SUSPENSION
  DEMANDA_NULIDAD
  AMPARO
  CONTESTACION
  REQUERIMIENTO
  NOTIFICACION
  ACTO_ADMINISTRATIVO
  OTRO
}

model Mensaje {
  id        String      @id @default(cuid())
  casoId    String?
  userId    String
  rol       RolMensaje
  contenido String      @db.Text
  modelo    String?     // claude-opus-4-7 | claude-sonnet-4-6 | deepseek-v3
  tokensIn  Int?
  tokensOut Int?
  createdAt DateTime    @default(now())

  caso Caso? @relation(fields: [casoId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([casoId])
  @@index([userId])
}

enum RolMensaje {
  USER
  ASSISTANT
  SYSTEM
}

model Sintesis {
  id                String   @id @default(cuid())
  casoId            String
  tipo              TipoSintesis
  contenidoMarkdown String   @db.Text
  datosEstructurados Json?    // créditos, plazos, fundamentos
  modelo            String
  generadaEn        DateTime @default(now())

  caso Caso @relation(fields: [casoId], references: [id], onDelete: Cascade)

  @@index([casoId])
}

enum TipoSintesis {
  EJECUTIVA
  PROFUNDA
  ESTRATEGIA_DEFENSA
}
